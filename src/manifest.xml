<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
           xsi:type="TaskPaneApp">

  <!-- ═══════════════════════════════════════════ -->
  <!-- Hermes AI - Word Add-in                    -->
  <!-- ═══════════════════════════════════════════ -->
  
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>0.1.0</Version>
  <ProviderName>Hermes AI</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Hermes AI Assistant"/>
  <Description DefaultValue="AI-powered document assistant. Chat, analyze, rewrite, and summarize your Word documents using Hermes AI."/>
  
  <IconUrl DefaultValue="https://localhost:8765/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://localhost:8765/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://github.com/yourusername/hermes-word-addin"/>
  
  <AppDomains>
    <AppDomain>https://localhost:8765</AppDomain>
    <AppDomain>http://localhost:8765</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Document"/>
  </Hosts>
  
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="WordApi" MinVersion="1.3"/>
    </Sets>
  </Requirements>
  
  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:8765/"/>
  </DefaultSettings>
  
  <Permissions>ReadWriteDocument</Permissions>

  <!-- ═══════════════════════════════════════════ -->
  <!-- VersionOverrides para Word 2016+           -->
  <!-- ═══════════════════════════════════════════ -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          
          <!-- Panel lateral (task pane) -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="HermesGroup">
                <Label resid="HermesGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>
                
                <!-- Boton en el ribbon -->
                <Control xsi:type="Button" id="ShowTaskpane">
                  <Label resid="ShowTaskpane.Label"/>
                  <Supertip>
                    <Title resid="ShowTaskpane.Title"/>
                    <Description resid="ShowTaskpane.Description"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>HermesTaskPane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
          
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://localhost:8765/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://localhost:8765/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://localhost:8765/assets/icon-80.png"/>
      </bt:Images>
      
      <bt:Urls>
        <bt:Url id="Taskpane.Url" DefaultValue="https://localhost:8765/"/>
      </bt:Urls>
      
      <bt:ShortStrings>
        <bt:String id="HermesGroup.Label" DefaultValue="Hermes AI"/>
        <bt:String id="ShowTaskpane.Label" DefaultValue="Open Hermes"/>
        <bt:String id="ShowTaskpane.Title" DefaultValue="Hermes AI Assistant"/>
      </bt:ShortStrings>
      
      <bt:LongStrings>
        <bt:String id="ShowTaskpane.Description" DefaultValue="Open Hermes AI chat panel to analyze, summarize, and rewrite your document."/>
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>

</OfficeApp>
